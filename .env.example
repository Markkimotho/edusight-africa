# ============================================================================
# EduSight Africa — Environment Variables
# Copy this file to .env and fill in real values before starting services.
# NEVER commit the actual .env file to version control.
# ============================================================================

# ── Backend ─────────────────────────────────────────────────────────────────

# Async PostgreSQL connection string (used by SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://edusight:edusight@localhost:5432/edusight

# Redis connection string (used for caching and task queues)
REDIS_URL=redis://localhost:6379

# JWT signing secrets — must be at least 32 random characters each
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-production

# JWT algorithm and token lifetimes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Runtime environment: development | staging | production
ENVIRONMENT=development

# ── Frontend ─────────────────────────────────────────────────────────────────

# Public API base URL (visible in the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
